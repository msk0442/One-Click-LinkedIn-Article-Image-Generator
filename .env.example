# Client-side configuration
# Note: In this application, API keys are input by the user on the client side
# via the Settings Panel (BYOK - Bring Your Own Key) to ensure maximum privacy.
# Do NOT hardcode your API keys here for production deployments.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=15000

# Optional Server-Side overrides (if you want to bypass BYOK for local testing)
# OPENAI_API_KEY=sk-...
# REPLICATE_API_TOKEN=r8_...
